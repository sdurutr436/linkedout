# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path relative to the project root (or /data/dev.db inside Docker)
DATABASE_URL="file:./data/dev.db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Long random string used to sign JWT session tokens.
# Generate one with: openssl rand -base64 64
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# ─── Anthropic / Claude API ───────────────────────────────────────────────────
# Obtain at https://console.anthropic.com
# Required for CV optimization feature
ANTHROPIC_API_KEY=""

# ─── Google Sheets integration ────────────────────────────────────────────────
# Create a Service Account in Google Cloud Console:
# 1. APIs & Services → Credentials → Create Service Account
# 2. Grant it "Editor" role on the target spreadsheet
# 3. Download the JSON key and paste the values below

# Service account email (e.g. linkedout@my-project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""

# Private key from the service account JSON (include -----BEGIN/END PRIVATE KEY-----)
# Replace literal newlines with \n
GOOGLE_SERVICE_ACCOUNT_KEY=""

# The ID of the target Google Spreadsheet (from its URL)
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_ID=""

# ─── Infojobs API ─────────────────────────────────────────────────────────────
# Register at https://developer.infojobs.net to obtain these.
# Used for job search (Basic auth) and user OAuth (apply on behalf of user).
INFOJOBS_CLIENT_ID=""
INFOJOBS_CLIENT_SECRET=""

# ─── App URL ──────────────────────────────────────────────────────────────────
# Full public URL of the app (used for CORS and Open Graph)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Observability ────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
